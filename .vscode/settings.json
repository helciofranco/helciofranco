{
  // AI & Chat Features
  "chat.agent.enabled": false,
  "chat.checkpoints.enabled": false,
  "chat.commandCenter.enabled": false,
  "github.copilot.chat.agent.autoFix": false,
  "github.copilot.chat.agent.runTasks": false,
  "github.copilot.chat.codeGeneration.useInstructionFiles": false,
  "github.copilot.chat.customInstructionsInSystemMessage": false,
  "github.copilot.chat.useProjectTemplates": false,
  "github.copilot.editor.enableCodeActions": false,
  "github.copilot.nextEditSuggestions.enabled": true,

  // Breadcrumbs
  "breadcrumbs.enabled": true,

  // Diff Editor
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": false,

  // Editor
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.lineHeight": 1.8,
  "editor.minimap.enabled": false,
  "editor.rulers": [80, 120],
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "visible",
  "editor.semanticHighlighting.enabled": false,
  "editor.tabSize": 2,

  // Explorer
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, turbo.json, biome.json, .prettierrc, vercel.json, yarn.lock, .npmrc, .npmignore, .nvmrc, pnpm-*.yaml",
    "bunfig.toml": "bun.lockb, bun.lock, .bun-version",
    ".rustfmt.toml": "Cargo.lock, Cargo.toml, fuel-toolchain.toml",
    ".gitignore": ".dockerignore, .prettierignore",
    "README.md": "LICENSE"
  },

  // Extensions
  "extensions.ignoreRecommendations": true,

  // Files & Search
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true
  },
  "search.exclude": {
    "**/generated": true,
    "**/dist": true,
    "**/.next": true,
    "**/tsconfig.tsbuildinfo": true,
    "**/public/storybook": true
  },

  // Git
  "git.confirmSync": false,
  "gitlens.currentLine.enabled": true,
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.recentChange.enabled": false,

  // Language-specific
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",

  // Window & Workbench
  "window.commandCenter": false,
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.editor.enablePreview": false,
  "workbench.editor.labelFormat": "short",
  "workbench.statusBar.visible": false
}
